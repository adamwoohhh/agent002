AGX_PROVIDER=openai
AGX_API_KEY=your_api_key_here
AGX_MODEL=gpt-4.1

# 可选：兼容 OpenAI 接口的服务基地址
# AGX_BASE_URL=https://your-compatible-endpoint/v1

# 可选：给 http provider 单独配置
# AGX_HTTP_URL=https://your-compatible-endpoint/v1/chat/completions
# AGX_HTTP_API_KEY=your_http_api_key_here
# AGX_HTTP_MODEL=gpt-4.1
# AGX_HTTP_TIMEOUT_MS=30000
