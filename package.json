{
  "name": "langgraph-ts-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "start": "node --import tsx src/index.ts",
    "log:view": "node --import tsx src/tools/log-viewer.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:agent",
    "test:unit": "node --import tsx --test tests/unit/**/*.test.ts",
    "test:agent": "node --import tsx --test tests/agent/**/*.test.ts",
    "eval:llm": "node --import tsx --test tests/llm/**/*.test.ts",
    "eval": "npm run test && npm run eval:llm"
  },
  "dependencies": {
    "@langchain/core": "^1.0.1",
    "@langchain/langgraph": "^1.0.0",
    "@next-ai/fornax-langchain": "^1.0.16",
    "@next-ai/fornax-sdk": "^2.4.4",
    "dotenv": "^17.4.2",
    "openai": "^6.34.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
